{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "手牌",
  "type": "object",
  "required": ["id", "name", "cardType", "handType", "tags", "timing", "effectText", "cards"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "cardType": { "type": "string", "const": "手牌" },
    "handType": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timing": { "type": "string" },
    "effectText": { "type": "string" },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["suit", "rank"],
        "properties": {
          "suit": { "type": "string", "enum": ["黑桃", "红桃", "梅花", "方块"] },
          "rank": { "type": "string" }
        }
      }
    }
  }
}
