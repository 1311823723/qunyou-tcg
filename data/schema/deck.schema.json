{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "预组",
  "type": "object",
  "required": ["id", "name", "archetype", "bodyId", "megaId", "characterIds"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "archetype": { "type": "string" },
    "bodyId": { "type": "string" },
    "megaId": { "type": "string" },
    "characterIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}
