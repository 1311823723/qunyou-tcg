---
import Layout from "../../components/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import BodyCard from "../../components/BodyCard.astro";
import { allBodies } from "../../lib/cards";
---
<Layout title="本体牌">
  <div class="page-wrap max-w-2xl">
    <PageHeader title="本体牌" subtitle="玩家核心 · 承受伤害 · 决定流派" />
    <div class="grid gap-6">
      {allBodies.map((b) => <BodyCard body={b} />)}
    </div>
  </div>
</Layout>
