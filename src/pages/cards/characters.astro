---
import Layout from "../../components/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import CharacterCard from "../../components/CharacterCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import EmptyState from "../../components/EmptyState.astro";
import { allCharacters, MAIN_ROLES, ALL_TAGS } from "../../lib/cards";

const url = new URL(Astro.request.url);
const role = url.searchParams.get("role") || "";
const tag = url.searchParams.get("tag") || "";
const search = url.searchParams.get("search") || "";

let filtered = allCharacters;
if (role) filtered = filtered.filter((c) => c.mainRole === role);
if (tag) filtered = filtered.filter((c) => c.tags.includes(tag));
if (search) {
  const q = search.toLowerCase();
  filtered = filtered.filter(
    (c) => c.name.toLowerCase().includes(q) || c.skillName.toLowerCase().includes(q) || c.effectText.toLowerCase().includes(q)
  );
}
---
<Layout title="角色牌">
  <div class="page-wrap">
    <PageHeader title="角色牌" subtitle={`${filtered.length} / ${allCharacters.length} 张 · 竖版 TCG 卡面`} />
    <FilterBar roles={[...MAIN_ROLES]} tags={ALL_TAGS} activeRole={role} activeTag={tag} search={search} />
    {filtered.length === 0 ? (
      <EmptyState message="没有匹配的角色牌，试试调整筛选条件" />
    ) : (
      <div class="card-gallery card-gallery--chars">
        {filtered.map((c) => <CharacterCard character={c} showDeck />)}
      </div>
    )}
  </div>
</Layout>
