---
import Layout from "../../components/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import MegaCard from "../../components/MegaCard.astro";
import { allMegas } from "../../lib/cards";
---
<Layout title="Mega 牌">
  <div class="page-wrap max-w-3xl">
    <PageHeader title="Mega 牌" subtitle="一次性强化形态 · 达成条件后展开的翻盘窗口。" badge="MEGA" />
    <div class="rules-mega-highlight mb-6">
      <p class="skill-text">Mega 牌每局只会在满足条件后登场一次。它应该带来强烈的节奏变化，但仍需要依赖本体与角色牌的前置铺垫。</p>
    </div>
    <div class="grid gap-6">
      {allMegas.map((m) => <MegaCard mega={m} />)}
    </div>
  </div>
</Layout>
