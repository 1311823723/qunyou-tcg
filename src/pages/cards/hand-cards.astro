---
import Layout from "../../components/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import HandCard from "../../components/HandCard.astro";
import { allHandCards, getHandCardTotal, getSuitDistribution, SUIT_SYMBOLS, ALL_SUITS } from "../../lib/cards";

const total = getHandCardTotal();
const suitDist = getSuitDistribution();
const basics = allHandCards.filter((c) => c.handType === "基础");
const tricks = allHandCards.filter((c) => c.handType === "锦囊");

// 计算牌堆概率
const handProbabilities = allHandCards.map((card) => {
  const count = card.cards.length;
  const probability = (count / total * 100).toFixed(1);
  const draw5 = ((1 - Math.pow((total - count) / total, 5)) * 100).toFixed(1);
  const draw2 = ((1 - Math.pow((total - count) / total, 2)) * 100).toFixed(1);
  return {
    ...card,
    count,
    probability,
    draw5,
    draw2,
  };
}).sort((a, b) => b.count - a.count);
---
<Layout title="手牌">
  <div class="page-wrap">
    <PageHeader title="手牌牌堆" subtitle={`${allHandCards.length} 种 · 共 ${total} 张 · 双方共用的攻防资源池。`} badge="SHARED DECK" />

    <div class="hud-panel mb-8 scroll-reveal" style="padding: 1rem 1.2rem;">
      <div class="text-xs mb-3" style="color: var(--text-muted); font-family: var(--font-mono); letter-spacing: 0.12em;">SUIT DISTRIBUTION</div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {ALL_SUITS.map((suit, i) => {
          const count = suitDist[suit] || 0;
          const red = suit === "红桃" || suit === "方块";
          return (
            <div
              class="text-center p-3 rounded-xl scroll-reveal"
              style={`background: rgba(0,0,0,0.25); border: 1px solid var(--border-soft); animation-delay: ${i * 0.1}s`}
            >
              <span class="text-2xl font-mono font-bold" style={red ? "color:#ff8888" : "color: var(--text-secondary)"}>{SUIT_SYMBOLS[suit]}</span>
              <div class="dist-bar mt-2"><div class="dist-bar__fill" style={`width:${(count/total)*100}%;background:${red?"#e06060":"#7080a0"}`}></div></div>
              <span class="text-xs font-mono mt-2 inline-block" style="color: var(--text-muted);">{suit} · {count}</span>
            </div>
          );
        })}
      </div>
    </div>

    <div class="hud-panel mb-8 scroll-reveal" style="padding: 1rem 1.2rem;">
      <div class="text-xs mb-3" style="color: var(--text-muted); font-family: var(--font-mono); letter-spacing: 0.12em;">牌堆概率计算器</div>
      <p class="skill-text mb-4">计算在共用 {total} 张手牌牌堆中，各牌的摸取概率。</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" style="border-collapse: separate; border-spacing: 0;">
          <thead>
            <tr style="background: rgba(0,0,0,0.3);">
              <th class="text-left p-2 rounded-tl-lg" style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem;">牌名</th>
              <th class="text-center p-2" style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem;">数量</th>
              <th class="text-center p-2" style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem;">单张概率</th>
              <th class="text-center p-2" style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem;">首摸5张至少1张</th>
              <th class="text-center p-2 rounded-tr-lg" style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem;">每回合摸2张至少1张</th>
            </tr>
          </thead>
          <tbody>
            {handProbabilities.map((card, index) => (
              <tr class="hover:bg-white/5 transition-colors" style={index % 2 === 0 ? "background: rgba(0,0,0,0.15);" : ""}>
                <td class="p-2 font-bold" style="color: var(--text-primary);">{card.name}</td>
                <td class="p-2 text-center font-mono" style="color: var(--text-gold);">{card.count}</td>
                <td class="p-2 text-center font-mono" style="color: var(--text-secondary);">{card.probability}%</td>
                <td class="p-2 text-center font-mono" style="color: var(--accent-aggro-hot);">{card.draw5}%</td>
                <td class="p-2 text-center font-mono" style="color: var(--accent-info);">{card.draw2}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs mt-3" style="color: var(--text-faint);">概率基于随机抽取计算，实际游戏会受弃牌、检索等操作影响。</p>
    </div>

    {basics.length > 0 && (
      <section class="mb-10 scroll-reveal">
        <h2 class="section-heading" style="font-size: 1rem;">基础牌</h2>
        <div class="card-gallery card-gallery--hand">
          {basics.map((c, i) => (
            <div class="scroll-reveal" style={`animation-delay: ${i * 0.1}s`}>
              <HandCard card={c} />
            </div>
          ))}
        </div>
      </section>
    )}

    {tricks.length > 0 && (
      <section class="scroll-reveal">
        <h2 class="section-heading" style="font-size: 1rem;">锦囊牌</h2>
        <div class="card-gallery card-gallery--hand">
          {tricks.map((c, i) => (
            <div class="scroll-reveal" style={`animation-delay: ${i * 0.1}s`}>
              <HandCard card={c} />
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
