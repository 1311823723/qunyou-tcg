---
import Layout from "../../components/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { allBodies, allMegas, allCharacters, allHandCards, getHandCardTotal } from "../../lib/cards";
---
<Layout title="全卡列表">
  <div class="page-wrap">
    <PageHeader title="卡牌图鉴" subtitle="收藏册 · 全部卡牌数据来自 JSON" badge="全卡" />
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      {[
        ["/cards/bodies", "本体", String(allBodies.length), "var(--color-role-attack)"],
        ["/cards/megas", "Mega", String(allMegas.length), "var(--color-mega-purple)"],
        ["/cards/characters", "角色", String(allCharacters.length), "var(--color-text-highlight)"],
        ["/cards/hand-cards", "手牌", `${allHandCards.length}种`, "var(--color-role-defend)"],
      ].map(([href, label, count, color]) => (
        <a href={href} class="collection-card text-center">
          <div class="collection-card__count" style={`color: ${color}`}>{count}</div>
          <div class="collection-card__label">{label}</div>
        </a>
      ))}
    </div>
    <p class="text-center text-sm" style="color: var(--color-text-muted);">共用手牌牌堆合计 {getHandCardTotal()} 张</p>
  </div>
</Layout>
