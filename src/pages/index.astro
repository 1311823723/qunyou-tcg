---
import Layout from "../components/Layout.astro";
import HeroCardShowcase from "../components/HeroCardShowcase.astro";
import { allBodies, allMegas, allCharacters, getHandCardTotal } from "../lib/cards";
import { allDecks } from "../lib/decks";
import { ARCHETYPE_KEYWORDS } from "../lib/ui";

const handTotal = getHandCardTotal();
const deck = allDecks[0];
const keywords = deck ? ARCHETYPE_KEYWORDS[deck.archetype] ?? [] : [];

const mechanics = [
  { icon: "♛", title: "本体", desc: "核心角色，承受伤害。体力归零即败。", color: "var(--color-role-attack)" },
  { icon: "?", title: "暗置上阵", desc: "背面朝上布阵，对手不知你的角色。", color: "var(--color-mega-purple)" },
  { icon: "↻", title: "休整", desc: "角色回牌堆底，常规技能成本，可循环。", color: "var(--color-text-highlight)" },
  { icon: "✕", title: "退场", desc: "送入退场区，强力技能的沉重代价。", color: "var(--color-role-attack)" },
  { icon: "★", title: "Mega", desc: "满足条件后一次性强化，翻盘爽感。", color: "var(--color-mega)" },
];
---
<Layout title="首页" description="群友杀 TCG — 本体承伤，角色暗置上阵，休整发动技能，Mega 后爆发反打。">
  <section class="hero-section page-wrap">
    <div class="hero-grid">
      <div>
        <p class="hero-eyebrow">v0.2 Demo · 1v1 对战卡牌</p>
        <h1 class="hero-title"><span>群友杀</span> TCG</h1>
        <p class="hero-sub">本体承伤，角色暗置上阵，休整发动技能，Mega 后爆发反打。</p>
        <div class="hero-actions">
          <a href="/rules" class="btn btn--primary">查看规则</a>
          <a href="/cards" class="btn btn--secondary">浏览全卡</a>
          <a href="/decks/aggro" class="btn btn--ghost">查看上头组</a>
        </div>
      </div>
      <HeroCardShowcase />
    </div>
  </section>

  <section class="page-wrap" style="margin-top: -0.5rem;">
    <div class="hud-panel">
      <div class="stat-hud">
        <div class="stat-hud__item">
          <div class="stat-hud__value" style="color: var(--color-role-attack)">{allBodies.length}</div>
          <div class="stat-hud__label">本体牌</div>
        </div>
        <div class="stat-hud__item">
          <div class="stat-hud__value" style="color: var(--color-mega-purple)">{allMegas.length}</div>
          <div class="stat-hud__label">Mega 牌</div>
        </div>
        <div class="stat-hud__item">
          <div class="stat-hud__value" style="color: var(--color-text-highlight)">{allCharacters.length}</div>
          <div class="stat-hud__label">角色牌</div>
        </div>
        <div class="stat-hud__item">
          <div class="stat-hud__value" style="color: var(--color-role-defend)">{allDecks.length}</div>
          <div class="stat-hud__label">预组</div>
        </div>
      </div>
      <p class="text-center text-xs mt-3" style="color: var(--color-text-muted);">共用手牌牌堆 {handTotal} 张 · 数据来自 JSON</p>
    </div>
  </section>

  <section class="page-wrap py-4">
    <h2 class="section-heading">核心机制</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      {mechanics.map((m) => (
        <div class="mechanic-tile" style={`border-top-color: ${m.color}`}>
          <div class="mechanic-tile__icon">{m.icon}</div>
          <div class="mechanic-tile__title" style={`color: ${m.color}`}>{m.title}</div>
          <p class="mechanic-tile__desc">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {deck && (
    <section class="page-wrap pb-12">
      <h2 class="section-heading">当前预组</h2>
      <div class="deck-spotlight">
        <div>
          <div class="deck-hero__title" style="font-size: 1.5rem; margin-bottom: 0.25rem;">{deck.name}</div>
          <div class="deck-hero__archetype">{deck.archetype}</div>
          <div class="flex flex-wrap gap-1 mt-3">
            {keywords.map((k) => <span class="tag-pill tag-pill--aggro">{k}</span>)}
          </div>
          {deck.notes && <p class="deck-hero__blurb" style="margin-top: 0.75rem; font-size: 0.85rem;">{deck.notes}</p>}
        </div>
        <a href="/decks/aggro" class="btn btn--primary">查看预组 →</a>
      </div>
    </section>
  )}
</Layout>
