---
import Layout from "../../components/Layout.astro";
import { getBattleCatalog } from "../../lib/battle-catalog";

const catalog = getBattleCatalog();
const featuredDeck = catalog.decks[0];
const featuredBody = featuredDeck ? catalog.cards[featuredDeck.bodyId] : undefined;
const featuredTheme = featuredDeck?.theme === "aggro" ? "deck-theme" : `deck-theme deck-theme--${featuredDeck?.theme || "neutral"}`;
---
<Layout title="在线对战" description="创建或加入群友杀 TCG 1v1 手动牌桌。">
  <div class="page-wrap battle-entry">
    <section class="battle-entry__hero">
      <div class="battle-entry__hero-copy">
        <span class="battle-entry__eyebrow"><i></i> 在线对战</span>
        <h1>开一桌，<br /><strong>和群友直接开打</strong></h1>
        <p>不用注册。创建房间或输入邀请码，进入准备室后再选择阵容。</p>
        <div class="battle-entry__status-row" aria-label="对战功能">
          <span>无需注册</span>
          <span>断线可恢复</span>
          <span>隐藏信息保护</span>
        </div>
      </div>
      {featuredDeck && (
        <aside class="battle-entry__preview" aria-label="牌组示例">
          <article class={`battle-deck-preview__card ${featuredTheme}`}>
            {featuredBody?.imagePath && <img src={featuredBody.imagePath} alt={`${featuredBody.name}卡面`} class="battle-deck-preview__art" />}
            <div>
              <span class="battle-deck-preview__tag">牌组示例 · {featuredDeck.archetype}</span>
              <strong>{featuredDeck.name}</strong>
              <p>{featuredDeck.blurb || featuredBody?.subtitle}</p>
            </div>
          </article>
        </aside>
      )}
    </section>

    <div id="battle-invite-banner" class="battle-entry__invite-banner" role="status" hidden>
      <span>收到对战邀请</span>
      <strong>你正在加入房间 <b data-invited-room>------</b></strong>
      <p>填写昵称即可进入准备室。</p>
    </div>

    <div class="battle-entry__grid" aria-label="开始在线对战">
      <section class="hud-panel battle-entry__panel battle-entry__panel--primary">
        <div class="battle-entry__panel-heading">
          <span class="battle-entry__step">01</span>
          <div><span>我来开房</span><h2>创建新房间</h2></div>
        </div>
        <p class="battle-entry__panel-copy">生成一条邀请链接，发给对手后在准备室选阵容。</p>
        <form id="create-room-form" class="battle-form">
          <label>昵称<input name="nickname" maxlength="20" required autocomplete="nickname" placeholder="你的昵称" /></label>
          <button class="btn btn--primary battle-entry__submit" type="submit"><span>创建房间</span><b>→</b></button>
          <p class="battle-form__status" data-form-status aria-live="polite" hidden></p>
        </form>
      </section>

      <section class="hud-panel battle-entry__panel battle-entry__panel--join" data-join-panel>
        <div class="battle-entry__panel-heading">
          <span class="battle-entry__step">02</span>
          <div><span>已有邀请</span><h2>加入对战房间</h2></div>
        </div>
        <p class="battle-entry__panel-copy">输入 6 位房间码，或直接打开对手发来的邀请链接。</p>
        <form id="join-room-form" class="battle-form">
          <label>房间码
            <input name="roomCode" class="battle-room-input" minlength="6" maxlength="6" required autocomplete="off" placeholder="6 位房间码" inputmode="text" autocapitalize="characters" spellcheck="false" />
          </label>
          <label>昵称<input name="nickname" maxlength="20" required autocomplete="nickname" placeholder="你的昵称" /></label>
          <button class="btn btn--secondary battle-entry__submit" type="submit"><span>加入房间</span><b>→</b></button>
          <p class="battle-form__status" data-form-status aria-live="polite" hidden></p>
        </form>
      </section>
    </div>

    <section class="battle-entry__notes">
      <div class="battle-entry__notes-heading">
        <span class="battle-entry__eyebrow"><i></i> 开局前须知</span>
        <h2>牌桌同步状态，<br />规则由双方结算</h2>
      </div>
      <div class="battle-entry__features">
        <article><span>01</span><strong>手动判定</strong><p>系统不自动判断技能、费用、伤害或胜负。</p></article>
        <article><span>02</span><strong>隐藏信息</strong><p>手牌和暗置角色仅对拥有者可见，查看会记入日志。</p></article>
        <article><span>03</span><strong>房间恢复</strong><p>刷新或短暂断线后，同一浏览器会自动认回座位。</p></article>
      </div>
    </section>
  </div>

  <script id="battle-entry-catalog" type="application/json" set:html={JSON.stringify(catalog)}></script>
</Layout>

<script>
  import { getBattleApiUrl } from "../../lib/battle-api";

  const API_URL = getBattleApiUrl();
  const TOKEN_KEY = "qunyou-battle-token-v1";
  const PENDING_KEY = "qunyou-battle-pending-v1";
  const CUSTOM_DECK_ID = "custom";
  const catalog = JSON.parse(document.querySelector("#battle-entry-catalog")?.textContent || "{}") as {
    cards?: Record<string, { kind?: string }>;
    decks?: Array<{ id: string }>;
  };
  const nicknameInputs = [...document.querySelectorAll<HTMLInputElement>('.battle-form input[name="nickname"]')];
  const joinRoomInput = document.querySelector<HTMLInputElement>('#join-room-form input[name="roomCode"]');
  const invitedRoomCode = new URLSearchParams(location.search).get("room")?.trim().toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 6) || "";

  function readPending() {
    try {
      const value = JSON.parse(localStorage.getItem(PENDING_KEY) || "null");
      return value && typeof value === "object" ? value : {};
    } catch {
      return {};
    }
  }

  function validCustomDeck(value: unknown) {
    if (!value || typeof value !== "object") return false;
    const deck = value as { bodyId?: string; characterIds?: unknown[] };
    return catalog.cards?.[deck.bodyId || ""]?.kind === "body"
      && Array.isArray(deck.characterIds)
      && deck.characterIds.length === 16
      && new Set(deck.characterIds).size === 16
      && deck.characterIds.every((id) => typeof id === "string" && catalog.cards?.[id]?.kind === "character");
  }

  function bootstrapLoadout() {
    const pending = readPending() as { deckId?: string; customDeck?: unknown };
    if (pending.deckId === CUSTOM_DECK_ID && validCustomDeck(pending.customDeck)) {
      return { deckId: CUSTOM_DECK_ID, customDeck: pending.customDeck };
    }
    if (catalog.decks?.some((deck) => deck.id === pending.deckId)) return { deckId: pending.deckId };
    return { deckId: catalog.decks?.[0]?.id || "" };
  }

  const rememberedNickname = String((readPending() as { nickname?: string }).nickname || "");
  nicknameInputs.forEach((input) => {
    input.value = rememberedNickname;
    input.addEventListener("input", () => {
      nicknameInputs.forEach((peer) => {
        if (peer !== input) peer.value = input.value;
      });
    });
  });

  if (invitedRoomCode.length === 6 && joinRoomInput) {
    joinRoomInput.value = invitedRoomCode;
    document.querySelector<HTMLElement>("[data-join-panel]")?.classList.add("is-invited");
    const banner = document.querySelector<HTMLElement>("#battle-invite-banner");
    if (banner) banner.hidden = false;
    const code = banner?.querySelector<HTMLElement>("[data-invited-room]");
    if (code) code.textContent = invitedRoomCode;
    document.querySelector<HTMLInputElement>('#join-room-form input[name="nickname"]')?.focus();
  }

  joinRoomInput?.addEventListener("input", () => {
    joinRoomInput.value = joinRoomInput.value.toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 6);
  });

  function token() {
    const saved = localStorage.getItem(TOKEN_KEY);
    if (saved) return saved;
    const created = typeof crypto.randomUUID === "function"
      ? crypto.randomUUID()
      : `${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}-${Math.random().toString(36).slice(2)}`;
    localStorage.setItem(TOKEN_KEY, created);
    return created;
  }

  function setFormStatus(form: HTMLFormElement, message: string, state = "info") {
    const element = form.querySelector<HTMLElement>("[data-form-status]");
    if (!element) return;
    element.textContent = message;
    element.dataset.state = state;
    element.hidden = !message;
  }

  function savePending(nickname: string, loadout: ReturnType<typeof bootstrapLoadout>) {
    localStorage.setItem(PENDING_KEY, JSON.stringify({ nickname, ...loadout }));
  }

  document.querySelector<HTMLFormElement>("#create-room-form")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const nickname = String(new FormData(form).get("nickname") || "").trim();
    const loadout = bootstrapLoadout();
    if (!button) return;
    const originalLabel = button.innerHTML;
    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 10000);
    button.disabled = true;
    button.textContent = "正在创建…";
    setFormStatus(form, "正在连接对战服务器并创建房间。", "loading");
    try {
      const response = await fetch(`${API_URL}/rooms`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ nickname, ...loadout, token: token() }),
        signal: controller.signal,
      });
      const result = await response.json().catch(() => ({})) as { roomCode?: string; error?: string };
      if (!response.ok) throw new Error(result.error || `创建房间失败（${response.status}）`);
      if (!result.roomCode) throw new Error("服务器未返回房间码，请稍后重试。");
      savePending(nickname, loadout);
      setFormStatus(form, `房间 ${result.roomCode} 已创建，正在进入准备室。`, "success");
      location.href = `/play/room?code=${result.roomCode}`;
    } catch (error) {
      const message = error instanceof DOMException && error.name === "AbortError"
        ? "创建房间超时。请检查网络后重试。"
        : error instanceof TypeError
          ? "无法连接对战服务器。请检查网络后重试。"
          : error instanceof Error ? error.message : "创建房间失败，请稍后重试。";
      setFormStatus(form, message, "error");
      button.disabled = false;
      button.innerHTML = originalLabel;
    } finally {
      window.clearTimeout(timeout);
    }
  });

  document.querySelector<HTMLFormElement>("#join-room-form")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const payload = Object.fromEntries(new FormData(form).entries());
    const nickname = String(payload.nickname || "").trim();
    const code = String(payload.roomCode || "").trim().toUpperCase();
    if (!/^[A-Z0-9]{6}$/.test(code)) {
      setFormStatus(form, "请输入 6 位房间码（字母或数字）。", "error");
      return;
    }
    const loadout = bootstrapLoadout();
    setFormStatus(form, "资料已保存，正在进入准备室。", "loading");
    savePending(nickname, loadout);
    location.href = `/play/room?code=${code}`;
  });
</script>
