---
import Layout from "../../components/Layout.astro";
import { getBattleCatalog } from "../../lib/battle-catalog";

const catalog = getBattleCatalog();
---
<Layout title="在线对战" description="创建或加入群友杀 TCG 1v1 手动牌桌。">
  <div class="page-wrap battle-entry">
    <section class="battle-entry__hero">
      <div class="battle-entry__hero-copy">
        <span class="battle-entry__eyebrow"><i></i> 1V1 ONLINE TABLE</span>
        <h1>把牌摆上桌，<br /><strong>规则由你们决定。</strong></h1>
        <p>两名玩家、一个房间码。保留实体桌游的自由操作，同时妥善处理手牌、暗置角色与断线恢复。</p>
        <div class="battle-entry__status-row" aria-label="在线牌桌特性">
          <span><i class="is-live"></i> 实时同步</span>
          <span>无需账号</span>
          <span>手机可用</span>
        </div>
      </div>
      <div class="battle-entry__preview hud-panel" id="battle-entry-preview" aria-live="polite"></div>
    </section>

    <div class="battle-entry__grid" aria-label="开始在线对战">
      <section class="hud-panel battle-entry__panel battle-entry__panel--primary">
        <div class="battle-entry__panel-heading">
          <span class="battle-entry__step">01</span>
          <div><span>HOST A TABLE</span><h2>创建牌桌</h2></div>
        </div>
        <form id="create-room-form" class="battle-form">
          <label>昵称<input name="nickname" maxlength="20" required autocomplete="nickname" placeholder="你的昵称" /></label>
          <label>预组
            <select name="deckId" required data-deck-select>
              {catalog.decks.map((deck) => <option value={deck.id}>{deck.name} · {deck.archetype}</option>)}
            </select>
          </label>
          <button class="btn btn--primary battle-entry__submit" type="submit"><span>创建牌桌</span><b>→</b></button>
          <p class="battle-form__status" data-form-status aria-live="polite" hidden></p>
        </form>
      </section>

      <section class="hud-panel battle-entry__panel battle-entry__panel--join">
        <div class="battle-entry__panel-heading">
          <span class="battle-entry__step">02</span>
          <div><span>JOIN A FRIEND</span><h2>加入房间</h2></div>
        </div>
        <form id="join-room-form" class="battle-form">
          <label>昵称<input name="nickname" maxlength="20" required autocomplete="nickname" placeholder="你的昵称" /></label>
          <label>房间码
            <input name="roomCode" class="battle-room-input" minlength="6" maxlength="6" required autocomplete="off" placeholder="6 位码" inputmode="text" autocapitalize="characters" spellcheck="false" />
          </label>
          <label>预组
            <select name="deckId" required data-deck-select>
              {catalog.decks.map((deck) => <option value={deck.id}>{deck.name} · {deck.archetype}</option>)}
            </select>
          </label>
          <button class="btn btn--secondary battle-entry__submit" type="submit"><span>加入牌桌</span><b>→</b></button>
          <p class="battle-form__status" data-form-status aria-live="polite" hidden></p>
        </form>
      </section>
    </div>

    <section class="battle-entry__notes">
      <div class="battle-entry__notes-heading">
        <span class="battle-entry__eyebrow"><i></i> BEFORE YOU PLAY</span>
        <h2>像在桌边一样自由，<br />但隐藏信息不会露出来。</h2>
      </div>
      <div class="battle-entry__features">
        <article><span>01</span><strong>手动结算</strong><p>系统不代替玩家判断技能、伤害和费用，复杂效果仍由双方协商处理。</p></article>
        <article><span>02</span><strong>隐藏信息</strong><p>对手只能看到手牌数量和卡背，查看行为会被明确记录。</p></article>
        <article><span>03</span><strong>断线恢复</strong><p>同一浏览器会自动认回座位，无人连接的房间保留 24 小时。</p></article>
      </div>
    </section>
  </div>

  <script id="battle-entry-catalog" type="application/json" set:html={JSON.stringify(catalog)}></script>
</Layout>

<script>
  import { getBattleApiUrl } from "../../lib/battle-api";

  const API_URL = getBattleApiUrl();
  const TOKEN_KEY = "qunyou-battle-token-v1";
  const catalog = JSON.parse(document.querySelector("#battle-entry-catalog")?.textContent || "{}");
  const invitedRoomCode = new URLSearchParams(location.search).get("room")?.trim().toUpperCase();
  const joinRoomInput = document.querySelector("#join-room-form input[name='roomCode']");
  const preview = document.querySelector("#battle-entry-preview");

  if (invitedRoomCode && joinRoomInput instanceof HTMLInputElement) {
    joinRoomInput.value = invitedRoomCode;
    document.querySelector("#join-room-form input[name='nickname']")?.focus();
  }

  joinRoomInput?.addEventListener("input", (event) => {
    const input = event.currentTarget;
    if (!(input instanceof HTMLInputElement)) return;
    input.value = input.value.toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 6);
  });

  function renderDeckPreview(deckId) {
    if (!preview) return;
    const deck = catalog.decks?.find((item) => item.id === deckId);
    const body = deck ? catalog.cards?.[deck.bodyId] : undefined;
    if (!deck) {
      preview.innerHTML = "";
      return;
    }
    const theme = deck.theme === "aggro" ? "deck-theme" : `deck-theme deck-theme--${deck.theme}`;
    preview.innerHTML = `<article class="battle-deck-preview__card ${theme}">
      ${body?.imagePath ? `<img src="${body.imagePath}" alt="" class="battle-deck-preview__art" loading="lazy" />` : ""}
      <div>
        <span class="battle-deck-preview__tag">${deck.archetype}</span>
        <strong>${deck.name}</strong>
        <p>${deck.blurb || body?.subtitle || ""}</p>
      </div>
    </article>`;
  }

  document.querySelectorAll("[data-deck-select]").forEach((select) => {
    renderDeckPreview(select.value);
    select.addEventListener("change", () => renderDeckPreview(select.value));
  });

  function token() {
    const saved = localStorage.getItem(TOKEN_KEY);
    if (saved) return saved;
    const created = typeof crypto.randomUUID === "function"
      ? crypto.randomUUID()
      : `${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}-${Math.random().toString(36).slice(2)}`;
    localStorage.setItem(TOKEN_KEY, created);
    return created;
  }

  function values(form) {
    return Object.fromEntries(new FormData(form).entries());
  }

  function setFormStatus(form, message, state = "info") {
    const element = form.querySelector("[data-form-status]");
    if (!(element instanceof HTMLElement)) return;
    element.textContent = message;
    element.dataset.state = state;
    element.hidden = !message;
  }

  document.querySelector("#create-room-form")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const button = form.querySelector("button");
    const originalLabel = button.textContent;
    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 10000);
    button.disabled = true;
    button.textContent = "正在创建…";
    setFormStatus(form, "正在连接对战服务器并创建房间，请稍候。", "loading");
    try {
      const payload = values(form);
      const response = await fetch(`${API_URL}/rooms`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ ...payload, token: token() }),
        signal: controller.signal,
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(result.error || `创建房间失败（${response.status}）`);
      if (!result.roomCode) throw new Error("服务器未返回房间码，请稍后重试。");
      localStorage.setItem("qunyou-battle-pending-v1", JSON.stringify({
        nickname: payload.nickname,
        deckId: payload.deckId,
      }));
      setFormStatus(form, `房间 ${result.roomCode} 创建成功，正在进入…`, "success");
      location.href = `/play/room?code=${result.roomCode}`;
    } catch (error) {
      const message = error instanceof DOMException && error.name === "AbortError"
        ? "创建房间超时。当前网络可能无法连接对战服务，请切换网络后重试。"
        : error instanceof TypeError
          ? "无法连接对战服务器。请检查网络后重试；若网页能打开但仍失败，请把此提示反馈给维护者。"
          : error instanceof Error ? error.message : "创建房间失败，请稍后重试。";
      setFormStatus(form, message, "error");
      button.disabled = false;
      button.textContent = originalLabel;
    } finally {
      window.clearTimeout(timeout);
    }
  });

  document.querySelector("#join-room-form")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const payload = values(form);
    const code = String(payload.roomCode).trim().toUpperCase();
    if (!/^[A-Z0-9]{6}$/.test(code)) {
      setFormStatus(form, "请输入 6 位房间码（字母或数字）。", "error");
      return;
    }
    setFormStatus(form, "资料已保存，正在进入房间…", "loading");
    localStorage.setItem("qunyou-battle-pending-v1", JSON.stringify({
      nickname: payload.nickname,
      deckId: payload.deckId,
    }));
    location.href = `/play/room?code=${code}`;
  });
</script>
