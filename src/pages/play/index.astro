---
import Layout from "../../components/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getBattleCatalog } from "../../lib/battle-catalog";

const catalog = getBattleCatalog();
---
<Layout title="在线对战" description="创建或加入群友杀 TCG 1v1 手动牌桌。">
  <div class="page-wrap battle-entry">
    <PageHeader title="在线对战" subtitle="两人、一个房间码，像在线 TTS 一样手动完成牌局。" badge="1V1 TABLE" />

    <div class="battle-entry__grid">
      <section class="hud-panel battle-entry__panel">
        <h2>创建房间</h2>
        <form id="create-room-form" class="battle-form">
          <label>昵称<input name="nickname" maxlength="20" required autocomplete="nickname" /></label>
          <label>预组
            <select name="deckId" required>
              {catalog.decks.map((deck) => <option value={deck.id}>{deck.name} · {deck.archetype}</option>)}
            </select>
          </label>
          <button class="btn btn--primary" type="submit">创建牌桌</button>
          <p class="battle-form__status" data-form-status aria-live="polite" hidden></p>
        </form>
      </section>

      <section class="hud-panel battle-entry__panel">
        <h2>加入房间</h2>
        <form id="join-room-form" class="battle-form">
          <label>昵称<input name="nickname" maxlength="20" required autocomplete="nickname" /></label>
          <label>房间码<input name="roomCode" minlength="6" maxlength="6" required autocomplete="off" /></label>
          <label>预组
            <select name="deckId" required>
              {catalog.decks.map((deck) => <option value={deck.id}>{deck.name} · {deck.archetype}</option>)}
            </select>
          </label>
          <button class="btn btn--secondary" type="submit">加入牌桌</button>
          <p class="battle-form__status" data-form-status aria-live="polite" hidden></p>
        </form>
      </section>
    </div>

    <section class="battle-entry__notes">
      <h2 class="section-heading">首版说明</h2>
      <div class="battle-entry__features">
        <p><strong>手动结算</strong><br />系统不判断技能、伤害和费用是否合法。</p>
        <p><strong>隐藏信息</strong><br />对手只能看到你的手牌数量和暗置卡背。</p>
        <p><strong>断线恢复</strong><br />同一浏览器会自动认回座位，房间保留 24 小时。</p>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { getBattleApiUrl } from "../../lib/battle-api";

  const API_URL = getBattleApiUrl();
  const TOKEN_KEY = "qunyou-battle-token-v1";
  const invitedRoomCode = new URLSearchParams(location.search).get("room")?.trim().toUpperCase();
  const joinRoomInput = document.querySelector("#join-room-form input[name='roomCode']");

  if (invitedRoomCode && joinRoomInput instanceof HTMLInputElement) {
    joinRoomInput.value = invitedRoomCode;
    document.querySelector("#join-room-form input[name='nickname']")?.focus();
  }

  function token() {
    const saved = localStorage.getItem(TOKEN_KEY);
    if (saved) return saved;
    const created = typeof crypto.randomUUID === "function"
      ? crypto.randomUUID()
      : `${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}-${Math.random().toString(36).slice(2)}`;
    localStorage.setItem(TOKEN_KEY, created);
    return created;
  }

  function values(form) {
    return Object.fromEntries(new FormData(form).entries());
  }

  function setFormStatus(form, message, state = "info") {
    const element = form.querySelector("[data-form-status]");
    if (!(element instanceof HTMLElement)) return;
    element.textContent = message;
    element.dataset.state = state;
    element.hidden = !message;
  }

  document.querySelector("#create-room-form")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const button = form.querySelector("button");
    const originalLabel = button.textContent;
    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 10000);
    button.disabled = true;
    button.textContent = "正在创建…";
    setFormStatus(form, "正在连接对战服务器并创建房间，请稍候。", "loading");
    try {
      const payload = values(form);
      const response = await fetch(`${API_URL}/rooms`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ ...payload, token: token() }),
        signal: controller.signal,
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(result.error || `创建房间失败（${response.status}）`);
      if (!result.roomCode) throw new Error("服务器未返回房间码，请稍后重试。");
      localStorage.setItem("qunyou-battle-pending-v1", JSON.stringify({
        nickname: payload.nickname,
        deckId: payload.deckId,
      }));
      setFormStatus(form, `房间 ${result.roomCode} 创建成功，正在进入…`, "success");
      location.href = `/play/room?code=${result.roomCode}`;
    } catch (error) {
      const message = error instanceof DOMException && error.name === "AbortError"
        ? "创建房间超时。当前网络可能无法访问 workers.dev，请切换网络或代理后重试。"
        : error instanceof TypeError
          ? "无法连接对战服务器。请检查当前网络是否能访问 workers.dev，必要时切换网络或代理。"
          : error instanceof Error ? error.message : "创建房间失败，请稍后重试。";
      setFormStatus(form, message, "error");
      button.disabled = false;
      button.textContent = originalLabel;
    } finally {
      window.clearTimeout(timeout);
    }
  });

  document.querySelector("#join-room-form")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const payload = values(form);
    const code = String(payload.roomCode).trim().toUpperCase();
    if (!/^[A-Z0-9]{6}$/.test(code)) {
      setFormStatus(form, "请输入 6 位房间码。", "error");
      return;
    }
    setFormStatus(form, "资料已保存，正在进入房间…", "loading");
    localStorage.setItem("qunyou-battle-pending-v1", JSON.stringify({
      nickname: payload.nickname,
      deckId: payload.deckId,
    }));
    location.href = `/play/room?code=${code}`;
  });
</script>
