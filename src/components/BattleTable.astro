---
import type { getBattleCatalog } from "../lib/battle-catalog";

export interface Props {
  catalog: ReturnType<typeof getBattleCatalog>;
}

const { catalog } = Astro.props;
---
<div class="battle-shell" id="battle-app">
  <header class="battle-topbar">
    <div class="battle-topbar__left">
      <a href="/play" class="battle-topbar__back" aria-label="退出牌桌">← <span>退出</span></a>
      <span class="battle-topbar__divider" aria-hidden="true"></span>
      <div class="battle-topbar__room">
        <span>ROOM</span>
        <strong id="battle-room-code" class="battle-topbar__code">------</strong>
      </div>
      <button type="button" id="battle-copy-code" class="battle-icon-btn battle-icon-btn--compact" title="复制房间码">复制码</button>
    </div>
    <div class="battle-topbar__center">
      <p class="battle-notice" id="battle-notice">
        <span class="battle-notice__dot" aria-hidden="true"></span>
        手动结算 · 系统不判定规则合法性
      </p>
    </div>
    <div class="battle-topbar__right">
      <span id="battle-connection" class="battle-connection" data-state="connecting" role="status">
        <span class="battle-connection__dot" aria-hidden="true"></span>
        <span class="battle-connection__text">连接中</span>
      </span>
      <div class="battle-topbar__desktop-actions">
        <button type="button" class="battle-icon-btn battle-mode-toggle" data-table-mode-toggle data-game-only aria-pressed="true">紧凑模式</button>
        <button type="button" class="battle-icon-btn battle-animation-toggle" data-animation-mode-toggle data-game-only>动画：打开</button>
        <button type="button" class="battle-icon-btn" data-shortcut-help data-game-only>快捷键</button>
        <a href="/rules" class="battle-icon-btn" target="_blank" rel="noopener">规则</a>
        <button type="button" class="battle-icon-btn" data-copy-invite data-game-only>邀请链接</button>
        <button type="button" class="battle-icon-btn" data-command="room:restartRequest" data-room-control="restart" data-game-only title="请求双方重新开始" hidden>重新开始</button>
        <button type="button" class="battle-icon-btn battle-icon-btn--danger" data-command="room:end">结束</button>
      </div>
      <details class="battle-topbar-menu">
        <summary class="battle-icon-btn battle-topbar-menu__trigger">菜单</summary>
        <div class="battle-topbar-menu__panel">
          <button type="button" class="battle-icon-btn battle-mode-toggle" data-table-mode-toggle data-game-only aria-pressed="true">紧凑模式</button>
          <button type="button" class="battle-icon-btn battle-animation-toggle" data-animation-mode-toggle data-game-only>动画：打开</button>
          <button type="button" class="battle-icon-btn" data-shortcut-help data-game-only>快捷键</button>
          <a href="/rules" class="battle-icon-btn" target="_blank" rel="noopener">查看规则</a>
          <button type="button" class="battle-icon-btn" data-copy-invite data-game-only>复制邀请链接</button>
          <button type="button" class="battle-icon-btn" data-command="room:restartRequest" data-room-control="restart" data-game-only hidden>重新开始</button>
          <button type="button" class="battle-icon-btn battle-icon-btn--danger" data-command="room:end">结束游戏</button>
        </div>
      </details>
    </div>
  </header>

  <div id="battle-toast" class="battle-toast" role="status" aria-live="polite" hidden></div>
  <div id="battle-announcer" class="battle-sr-only" role="status" aria-live="polite" aria-atomic="true"></div>
  <div id="battle-effect-layer" class="battle-effect-layer" aria-hidden="true"></div>

  <main id="battle-root" class="battle-root">
    <section class="battle-loading hud-panel">
      <div class="battle-loading__signal" aria-hidden="true"><i></i><i></i><i></i></div>
      <span class="battle-kicker">CONNECTING TO TABLE</span>
      <h1>正在连接牌桌</h1>
      <p>正在恢复匿名座位与牌局状态。同一浏览器会自动认回座位。</p>
    </section>
  </main>

  <div id="battle-coach" class="battle-coach" hidden>
    <div class="battle-coach__backdrop"></div>
    <div class="battle-coach__card hud-panel">
      <span class="battle-kicker">新手指引</span>
      <h2 id="battle-coach-title"></h2>
      <p id="battle-coach-text"></p>
      <div class="battle-coach__actions">
        <button type="button" id="battle-coach-skip" class="battle-small-btn">跳过</button>
        <button type="button" id="battle-coach-next" class="btn btn--primary">下一步</button>
      </div>
    </div>
  </div>

  <dialog id="battle-dialog" class="battle-dialog">
    <form method="dialog" class="battle-dialog__frame">
      <button class="battle-dialog__close" value="close" aria-label="关闭">×</button>
      <div id="battle-dialog-content"></div>
    </form>
  </dialog>

  <script id="battle-catalog" type="application/json" set:html={JSON.stringify(catalog)}></script>
</div>

<script>
  import "../scripts/battle-client";
</script>
