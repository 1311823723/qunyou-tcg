---
import Layout from "./Layout.astro";
import BodyCard from "./BodyCard.astro";
import CharacterCard from "./CharacterCard.astro";
import DeckPlayGuide from "./DeckPlayGuide.astro";
import { getDeckById, resolveDeck, getRoleDistribution, getTagDistribution } from "../lib/decks";
import { getDeckGuide } from "../lib/deck-guides";
import { getArchetypeKeywords, getArchetypeBlurb, getArchetypeRisks } from "../lib/archetypes";
import { ROLE_COLORS_CSS, archetypeThemeClass } from "../lib/ui";

interface Props {
  deckId: string;
}

const { deckId } = Astro.props;
const deck = getDeckById(deckId);
if (!deck) throw new Error(`Deck not found: ${deckId}`);
const resolved = resolveDeck(deck);
const guide = getDeckGuide(deck.id);
const roleDist = getRoleDistribution(resolved.characters);
const tagDist = getTagDistribution(resolved.characters);
const keywords = getArchetypeKeywords(deck.archetype);
const blurb = getArchetypeBlurb(deck.archetype);
const risk = getArchetypeRisks(deck.archetype);

const roleOrder = ["强攻", "防御", "资源", "控制", "支援", "伏击"];
const sortedRoleDist = Object.entries(roleDist).sort(([a], [b]) => roleOrder.indexOf(a) - roleOrder.indexOf(b));
const sortedTagDist = Object.entries(tagDist).sort(([, a], [, b]) => b - a);
const exitCount = resolved.characters.filter((card) => card.cost.type === "退场" || card.cost.type === "复合").length;
const restCosts = resolved.characters.filter((card) => card.cost.type === "休整").map((card) => card.cost.amount ?? 1);
const restDist: Record<string, number> = {};
for (const amount of restCosts) restDist[String(amount)] = (restDist[String(amount)] || 0) + 1;
const selfRestCount = resolved.characters.filter((card) => card.cost.type === "休整自身").length;
---
<Layout title={deck.name}>
  <div class={`page-wrap ${archetypeThemeClass(deck.archetype)}`}>
    <header class="deck-hero">
      <div class="tag-pill tag-pill--deck mb-3">PRECONSTRUCTED DECK</div>
      <h1 class="deck-hero__title">{deck.name}</h1>
      <div class="deck-hero__archetype">{deck.archetype}</div>
      {blurb && <p class="deck-hero__blurb">{blurb}</p>}
      {risk && <p class="deck-hero__risk">风险：{risk}</p>}
      <div class="flex flex-wrap gap-1 mt-4">
        {keywords.map((keyword) => <span class="tag-pill tag-pill--deck">{keyword}</span>)}
      </div>
      {deck.notes && <p class="deck-hero__blurb" style="font-size: 0.88rem; margin-top: 1rem; opacity: 0.9;">{deck.notes}</p>}
    </header>

    <section class="mb-10">
      <h2 class="section-heading" style="font-size: 1.1rem;">本体 · Z招式</h2>
      <p class="skill-text mb-4" style="max-width: 36rem;">点击本体卡下方按钮翻面查看Z招式。达成条件后翻面进入Z就绪状态，每局限发动一次。</p>
      <div class="max-w-md">{resolved.body && <BodyCard body={resolved.body} />}</div>
    </section>

    {guide && <DeckPlayGuide guide={guide} />}

    {guide && (guide.coreCards || guide.replaceableCards || guide.replaceSuggestions) && (
      <section class="hud-panel mb-10" style="padding: 1.25rem;">
        <h2 class="section-heading" style="font-size: 1.1rem;">构筑建议</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {guide.coreCards && guide.coreCards.length > 0 && (
            <div>
              <h3 class="font-bold text-sm mb-2" style="color: var(--color-text-highlight);">核心卡（不能替换）</h3>
              <ul class="space-y-1">
                {guide.coreCards.map((cardId) => {
                  const card = resolved.characters.find((c) => c.id === cardId);
                  return card ? (
                    <li class="skill-text flex items-center gap-2">
                      <span class="tag-pill tag-pill--role" style={`--role-color: var(--role-${card.mainRole === "强攻" ? "attack" : card.mainRole === "防御" ? "defend" : card.mainRole === "资源" ? "resource" : card.mainRole === "控制" ? "control" : card.mainRole === "支援" ? "support" : "ambush"});`}>{card.mainRole}</span>
                      <span class="font-bold">{card.name}</span>
                      <span class="text-xs" style="color: var(--text-muted);">— {card.skillName}</span>
                    </li>
                  ) : null;
                })}
              </ul>
            </div>
          )}
          {guide.replaceableCards && guide.replaceableCards.length > 0 && (
            <div>
              <h3 class="font-bold text-sm mb-2" style="color: var(--text-muted);">可替换卡</h3>
              <ul class="space-y-1">
                {guide.replaceableCards.map((cardId) => {
                  const card = resolved.characters.find((c) => c.id === cardId);
                  return card ? (
                    <li class="skill-text flex items-center gap-2">
                      <span class="tag-pill tag-pill--role" style={`--role-color: var(--role-${card.mainRole === "强攻" ? "attack" : card.mainRole === "防御" ? "defend" : card.mainRole === "资源" ? "resource" : card.mainRole === "控制" ? "control" : card.mainRole === "支援" ? "support" : "ambush"});`}>{card.mainRole}</span>
                      <span>{card.name}</span>
                      <span class="text-xs" style="color: var(--text-muted);">— {card.skillName}</span>
                    </li>
                  ) : null;
                })}
              </ul>
            </div>
          )}
        </div>
        {guide.replaceSuggestions && guide.replaceSuggestions.length > 0 && (
          <div class="mt-4">
            <h3 class="font-bold text-sm mb-2" style="color: var(--accent-info);">替换建议</h3>
            <ul class="space-y-2">
              {guide.replaceSuggestions.map((suggestion) => {
                const card = resolved.characters.find((c) => c.id === suggestion.card);
                return (
                  <li class="skill-text flex items-start gap-2">
                    <span class="font-bold" style="color: var(--text-gold);">{card ? card.name : suggestion.card}</span>
                    <span>— {suggestion.reason}</span>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
      </section>
    )}

    <section class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
      <div class="stat-hud__item">
        <div class="stat-hud__value" style="color: var(--color-role-attack)">{resolved.body?.hp ?? "?"}</div>
        <div class="stat-hud__label">本体体力</div>
      </div>
      <div class="stat-hud__item">
        <div class="stat-hud__value" style="color: var(--color-text-highlight)">{resolved.characters.length}</div>
        <div class="stat-hud__label">角色牌</div>
      </div>
      <div class="stat-hud__item">
        <div class="stat-hud__value" style="color: var(--color-mega-purple)">{exitCount}</div>
        <div class="stat-hud__label">退场/复合费用</div>
      </div>
      <div class="stat-hud__item">
        <div class="stat-hud__value" style="color: var(--color-role-ambush)">{resolved.characters.filter((card) => card.mainRole === "伏击").length}</div>
        <div class="stat-hud__label">伏击定位</div>
      </div>
    </section>

    <section class="grid md:grid-cols-2 gap-4 mb-10">
      <div class="hud-panel" style="padding: 1.1rem;">
        <h3 class="font-bold text-sm mb-3" style="color: var(--color-text-highlight);">主定位分布</h3>
        <div class="space-y-2">
          {sortedRoleDist.map(([role, count]) => (
            <div class="flex items-center gap-2">
              <span class="text-xs w-12" style="color: var(--text-muted);">{role}</span>
              <div class="dist-bar flex-1">
                <div class="dist-bar__fill" style={`width: ${(count / 16) * 100}%; background: ${ROLE_COLORS_CSS[role] || "#888"}`}></div>
              </div>
              <span class="text-xs font-bold w-4">{count}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hud-panel" style="padding: 1.1rem;">
        <h3 class="font-bold text-sm mb-3" style="color: var(--color-text-highlight);">标签分布</h3>
        <div class="flex flex-wrap gap-1">
          {sortedTagDist.map(([tag, count]) => <span class="tag-pill tag-pill--mech">{tag} ×{count}</span>)}
        </div>
        <h3 class="font-bold text-sm mt-5 mb-2" style="color: var(--color-text-highlight);">休整费用分布</h3>
        <div class="flex flex-wrap gap-2">
          {Object.entries(restDist).sort(([a], [b]) => Number(a) - Number(b)).map(([amount, count]) => (
            <span class="tag-pill tag-pill--deck">休整 {amount} ×{count}</span>
          ))}
          {selfRestCount > 0 && <span class="tag-pill tag-pill--deck">休整自身 ×{selfRestCount}</span>}
        </div>
      </div>
    </section>

    <h2 class="section-heading">完整角色牌 · {resolved.characters.length}</h2>
    <div class="card-gallery card-gallery--chars">
      {resolved.characters.map((character) => <CharacterCard character={character} />)}
    </div>
  </div>
</Layout>
