---
import CardFrame from "./CardFrame.astro";
import TagPill from "./TagPill.astro";
import type { BodyCard as BodyType } from "../lib/cards";

export interface Props { body: BodyType; compact?: boolean; }
const { body: b, compact } = Astro.props;
---
<CardFrame class={`tcg-body ${compact ? "tcg-char--compact" : ""}`}>
  <div class="tcg-body__banner">
    <div>
      <div class="tcg-body__type">本体 · {b.archetype}</div>
      <h3 class="tcg-body__name">{b.name}</h3>
    </div>
    <div class="tcg-body__hp">
      <div class="tcg-body__hp-val">{b.hp}</div>
      <div class="tcg-body__hp-label">体力</div>
    </div>
  </div>
  <div class="tcg-body__body">
    <div class="flex flex-wrap gap-1 mb-3">
      {b.affinityTags.map((tag) => <TagPill label={tag} variant="aggro" />)}
    </div>
    <div class="tcg-char__skill-name">{b.skillName}</div>
    <p class="skill-text mt-2">{b.effectText}</p>
  </div>
  <div class="tcg-body__mega-box">
    <div class="tcg-body__mega-label">Mega 条件</div>
    <p class="skill-text" style="color: var(--color-text-primary); font-weight: 500;">{b.megaCondition}</p>
  </div>
  {b.notes && <p class="tcg-char__notes" style="margin: 0 1rem 1rem;">{b.notes}</p>}
</CardFrame>
