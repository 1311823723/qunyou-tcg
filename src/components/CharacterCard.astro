---
import CardFrame from "./CardFrame.astro";
import TagPill from "./TagPill.astro";
import type { CharacterCard as CharType } from "../lib/cards";

export interface Props {
  character: CharType;
  showDeck?: boolean;
}
const { character: c, showDeck } = Astro.props;

// Split name: "刺客-柯柯" → prefix "刺客", suffix "柯柯"
const dashIdx = c.name.indexOf("-");
const namePrefix = dashIdx > 0 ? c.name.slice(0, dashIdx) : "";
const nameSuffix = dashIdx > 0 ? c.name.slice(dashIdx + 1) : c.name;

const costText = c.cost.type === "休整"
  ? `休整 ${c.cost.amount}`
  : c.cost.type === "退场"
  ? "退场自身"
  : c.cost.type === "复合"
  ? (c.cost.text || "复合")
  : c.cost.type;

const costEmoji = c.cost.type === "休整" ? "↻" : c.cost.type === "退场" ? "✕" : c.cost.type === "复合" ? "⚡" : "○";
const costColor = c.cost.type === "休整" ? "var(--color-accent-gold)" : c.cost.type === "退场" ? "var(--color-accent-red)" : c.cost.type === "复合" ? "var(--color-accent-purple)" : "var(--color-text-muted)";

const roleColorMap: Record<string, string> = {
  "强攻": "var(--color-tag-attack)",
  "防御": "var(--color-tag-defend)",
  "资源": "var(--color-tag-resource)",
  "控制": "var(--color-tag-control)",
  "支援": "var(--color-tag-support)",
  "伏击": "var(--color-tag-ambush)",
};
const roleColor = roleColorMap[c.mainRole] || "var(--color-text-muted)";
---
<CardFrame class="flex flex-col gap-3 group" style={`border-top: 2px solid ${roleColor}`}>
  <!-- Header: name + role pill -->
  <div class="flex items-start justify-between gap-2">
    <div class="min-w-0 flex-1">
      {namePrefix && (
        <div class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] opacity-60 mb-0.5">{namePrefix}</div>
      )}
      <h3 class="font-bold text-base text-[var(--color-text-primary)] truncate">{nameSuffix}</h3>
    </div>
    <TagPill label={c.mainRole} variant="role" role={c.mainRole} />
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1">
    {c.tags.map(tag => <TagPill label={tag} />)}
  </div>

  <!-- Cost + Timing -->
  <div class="flex items-center gap-3 text-xs flex-wrap">
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md font-semibold text-xs" style={`background:${costColor}15;color:${costColor};border:1px solid ${costColor}30`}>
      <span>{costEmoji}</span> {costText}
    </span>
    <span class="text-[var(--color-text-muted)]">
      <span class="opacity-50">⏱</span> {c.timing}
    </span>
    {showDeck && (
      <span class="text-[var(--color-text-muted)] opacity-60 ml-auto text-[10px]">{c.deck}</span>
    )}
  </div>

  <!-- Skill -->
  <div class="border-t border-[var(--color-border-card)] pt-2 mt-1">
    <span class="text-sm font-semibold text-[var(--color-accent-gold)]">{c.skillName}</span>
  </div>
  <p class="skill-text text-sm leading-relaxed">{c.effectText}</p>
</CardFrame>
