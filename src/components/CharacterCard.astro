---
import CardFrame from "./CardFrame.astro";
import TagPill from "./TagPill.astro";
import type { CharacterCard as CharType } from "../lib/cards";
import { splitCharacterName, formatCharacterCost, costKind, roleVar } from "../lib/ui";

export interface Props {
  character: CharType;
  showDeck?: boolean;
  compact?: boolean;
}
const { character: c, showDeck, compact } = Astro.props;
const { prefix, suffix } = splitCharacterName(c.name);
const costText = formatCharacterCost(c.cost);
const ck = costKind(c.cost);
const rv = roleVar(c.mainRole);
---
<CardFrame class={`tcg-char ${compact ? "tcg-char--compact" : ""}`} role={rv}>
  <header class="tcg-char__head">
    <div>
      {prefix && <div class="tcg-char__profession">{prefix}</div>}
      <h3 class="tcg-char__name">{suffix}</h3>
    </div>
    <TagPill label={c.mainRole} variant="role" role={c.mainRole} />
  </header>
  <div class="tcg-char__art" aria-hidden="true"></div>
  <div class="tcg-char__tags">
    {c.tags.map((tag) => <TagPill label={tag} />)}
  </div>
  <div class="tcg-char__meta">
    <span class={`tcg-char__cost tcg-char__cost--${ck}`}>{costText}</span>
    <span class="tcg-char__timing">⏱ {c.timing}</span>
  </div>
  <div class="tcg-char__skill">
    <div class="tcg-char__skill-name">{c.skillName}</div>
    <p class="tcg-char__skill-text">{c.effectText}</p>
  </div>
  {showDeck && <div class="tcg-char__deck">{c.deck}</div>}
  {c.notes && <p class="tcg-char__notes">{c.notes}</p>}
</CardFrame>
