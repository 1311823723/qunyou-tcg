---
import CardFrame from "./CardFrame.astro";
import TagPill from "./TagPill.astro";
import type { CharacterCard as CharType } from "../lib/cards";
import { splitCharacterName, formatCharacterCost, costKind, roleVar } from "../lib/ui";
import { getCharacterArt } from "../lib/card-art";

export interface Props {
  character: CharType;
  showDeck?: boolean;
  compact?: boolean;
}
const { character: c, showDeck, compact } = Astro.props;
const { prefix, suffix } = splitCharacterName(c.name);
const costText = formatCharacterCost(c.cost);
const ck = costKind(c.cost);
const rv = roleVar(c.mainRole);
const art = getCharacterArt(c.id);
const textLength = c.effectText.length + c.timing.length + (c.notes?.length ?? 0) * 2;
const textDensity = textLength > 90 ? "dense" : textLength > 65 ? "medium" : "normal";
---
<CardFrame class={`tcg-char tcg-char--${textDensity} ${art ? "tcg-char--with-art" : ""} ${c.notes ? "tcg-char--with-notes" : ""} ${compact ? "tcg-char--compact" : ""}`} role={rv} kind="character">
  {art && (
    <img
      class="tcg-card__full-art tcg-card__full-art--character"
      src={art.src}
      width={art.width}
      height={art.height}
      alt=""
      loading="lazy"
      aria-hidden="true"
    />
  )}
  <header class="tcg-char__head">
    <div>
      {prefix && <div class="tcg-char__profession">{prefix}</div>}
      <h3 class="tcg-char__name">{suffix}</h3>
    </div>
    <div class="tcg-char__badges">
      {c.source && <span class={`tcg-char__source tcg-char__source--${c.source}`}>{c.source}</span>}
      <TagPill label={c.mainRole} variant="role" role={c.mainRole} />
    </div>
  </header>
  <div class={`tcg-char__art ${art ? "tcg-char__art--image" : ""}`} aria-hidden="true"></div>
  <div class="tcg-char__tags">
    {c.tags.map((tag) => <TagPill label={tag} />)}
  </div>
  <div class="tcg-char__meta">
    <div class={`tcg-char__cost tcg-char__cost--${ck}`}>
      <span class="tcg-char__meta-label">COST</span>
      {costText}
    </div>
    <div class="tcg-char__timing">
      <span class="tcg-char__meta-label">TIMING</span>
      {c.timing}
    </div>
  </div>
  <div class="tcg-char__skill">
    <div class="tcg-char__skill-name">{c.skillName}</div>
    <p class="tcg-char__skill-text">{c.effectText}</p>
  </div>
  {showDeck && <div class="tcg-char__deck">DECK · {c.deck || "通用"}</div>}
  {c.notes && <p class="tcg-char__notes">{c.notes}</p>}
</CardFrame>
