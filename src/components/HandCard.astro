---
import CardFrame from "./CardFrame.astro";
import TagPill from "./TagPill.astro";
import type { HandCard as HandType } from "../lib/cards";
import { SUIT_SYMBOLS, isRedSuit } from "../lib/cards";

export interface Props {
  card: HandType;
}
const { card: h } = Astro.props;

const typeColor = h.handType === "基础" ? "var(--color-accent-cyan)" : "var(--color-accent-purple)";
---
<CardFrame class="flex flex-col gap-3" style={`border-left: 3px solid ${typeColor}`}>
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-bold text-lg text-[var(--color-text-primary)]">{h.name}</h3>
    <span class="text-[10px] px-2 py-0.5 rounded-full font-semibold uppercase tracking-wide" style={`background:${typeColor}15;color:${typeColor}`}>{h.handType}</span>
  </div>

  <div class="flex flex-wrap gap-1">
    {h.tags.map(tag => <TagPill label={tag} />)}
  </div>

  <!-- Suit/rank display -->
  <div class="flex flex-wrap gap-1.5">
    {h.cards.map(c => (
      <span
        class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-xs font-mono font-bold border"
        style={isRedSuit(c.suit)
          ? "color:#e06060;background:rgba(224,96,96,0.08);border-color:rgba(224,96,96,0.2)"
          : "color:var(--color-text-secondary);background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.08)"
        }
      ><span>{SUIT_SYMBOLS[c.suit]}</span>{c.rank}</span>
    ))}
  </div>

  <div class="text-xs text-[var(--color-text-muted)]">
    <span class="opacity-50">⏱</span> {h.timing}
  </div>

  <p class="skill-text text-sm leading-relaxed">{h.effectText}</p>
</CardFrame>
