---
import CardFrame from "./CardFrame.astro";
import TagPill from "./TagPill.astro";
import type { HandCard as HandType } from "../lib/cards";
import { SUIT_SYMBOLS, isRedSuit } from "../lib/cards";

export interface Props { card: HandType; }
const { card: h } = Astro.props;
const isTrick = h.handType === "锦囊";
---
<CardFrame class={`tcg-hand ${isTrick ? "tcg-hand--trick" : ""}`}>
  <div class="tcg-hand__row">
    <h3 class="tcg-hand__name">{h.name}</h3>
    <span class="tcg-hand__count">×{h.cards.length}</span>
  </div>
  <span class="tag-pill tag-pill--mech" style="margin-bottom: 0.35rem;">{h.handType}</span>
  <div class="flex flex-wrap gap-1 mb-2">
    {h.tags.map((tag) => <TagPill label={tag} />)}
  </div>
  <div class="tcg-hand__suits">
    {h.cards.map((c) => (
      <span class={`suit-chip ${isRedSuit(c.suit) ? "suit-chip--red" : ""}`}>
        {SUIT_SYMBOLS[c.suit]}{c.rank}
      </span>
    ))}
  </div>
  <div class="text-xs mb-2" style="color: var(--color-text-muted);">⏱ {h.timing}</div>
  <p class="skill-text">{h.effectText}</p>
</CardFrame>
