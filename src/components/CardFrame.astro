---
export interface Props {
  class?: string;
  role?: string;
  kind?: "character" | "body" | "mega" | "hand" | "trick";
}
const { class: extraClass = "", role, kind = "character" } = Astro.props;
---
<div class={`card-frame ${extraClass}`} data-kind={kind} {...(role ? { "data-role": role } : {})}>
  <slot />
</div>
