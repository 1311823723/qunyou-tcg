---
export interface Props {
  roles?: string[];
  tags?: string[];
  activeRole?: string;
  activeTag?: string;
  search?: string;
  roleLabel?: string;
  allLabel?: string;
}
const {
  roles = [],
  tags = [],
  activeRole = "",
  activeTag = "",
  search = "",
  roleLabel = "定位",
  allLabel = "全部",
} = Astro.props;
const currentPath = Astro.url.pathname;

function hrefFor(params: Record<string, string | undefined>) {
  const u = new URL(currentPath, "http://x");
  if (params.role !== undefined) {
    if (params.role) u.searchParams.set("role", params.role);
    else u.searchParams.delete("role");
  }
  if (params.tag !== undefined) {
    if (params.tag) u.searchParams.set("tag", params.tag);
    else u.searchParams.delete("tag");
  }
  if (params.search !== undefined) {
    if (params.search) u.searchParams.set("search", params.search);
    else u.searchParams.delete("search");
  }
  return u.pathname + u.search;
}
---
<div class="filter-panel">
  <input
    type="search"
    placeholder="搜索名称、技能…"
    value={search}
    id="filter-search"
    class="filter-search"
    autocomplete="off"
  />
  {roles.length > 0 && (
    <div class="filter-group">
      <span class="filter-group__label">{roleLabel}</span>
      <a href={hrefFor({ role: "", tag: activeTag || undefined, search: search || undefined })} class={`filter-chip ${!activeRole ? "is-active" : ""}`}>{allLabel}</a>
      {roles.map((r) => (
        <a href={hrefFor({ role: r, tag: activeTag || undefined, search: search || undefined })} class={`filter-chip ${activeRole === r ? "is-active" : ""}`}>{r}</a>
      ))}
    </div>
  )}
  {tags.length > 0 && (
    <div class="filter-group">
      <span class="filter-group__label">标签</span>
      <a href={hrefFor({ role: activeRole || undefined, tag: "", search: search || undefined })} class={`filter-chip ${!activeTag ? "is-active" : ""}`}>{allLabel}</a>
      {tags.map((t) => (
        <a href={hrefFor({ role: activeRole || undefined, tag: t, search: search || undefined })} class={`filter-chip ${activeTag === t ? "is-active" : ""}`}>{t}</a>
      ))}
    </div>
  )}
</div>
<script>
  const input = document.getElementById("filter-search");
  if (input) {
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const url = new URL(window.location.href);
        const v = (input as HTMLInputElement).value.trim();
        if (v) url.searchParams.set("search", v);
        else url.searchParams.delete("search");
        window.location.href = url.toString();
      }
    });
  }
</script>
