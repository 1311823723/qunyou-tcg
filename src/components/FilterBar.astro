---
export interface Props {
  roles?: string[];
  tags?: string[];
  activeRole?: string;
  activeTag?: string;
  search?: string;
  roleLabel?: string;
  allLabel?: string;
}
const {
  roles = [],
  tags = [],
  activeRole = "",
  activeTag = "",
  search = "",
  roleLabel = "定位",
  allLabel = "全部",
} = Astro.props;

const currentPath = Astro.url.pathname;
---
<div class="filter-bar">
  <!-- Search -->
  <input
    type="text"
    placeholder="搜索名称、技能..."
    value={search}
    id="filter-search"
    class="px-3 py-1.5 rounded-lg bg-[var(--color-bg-surface)] border border-[var(--color-border-card)] text-sm text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-border-accent)] w-48"
  />

  <!-- Role filter -->
  {roles.length > 0 && (
    <div class="flex flex-wrap gap-1 items-center">
      <span class="text-xs text-[var(--color-text-muted)] mr-1">{roleLabel}:</span>
      <a
        href={`${currentPath}${search ? `?search=${search}` : ""}`}
        class={`tag-pill no-underline ${!activeRole ? "bg-white/10 text-[var(--color-text-primary)]" : "mechanic"}`}
      >{allLabel}</a>
      {roles.map(r => (
        <a
          href={`${currentPath}?role=${r}${search ? `&search=${search}` : ""}`}
          class={`tag-pill no-underline ${activeRole === r ? "bg-white/15 text-[var(--color-text-primary)]" : "mechanic"}`}
        >{r}</a>
      ))}
    </div>
  )}

  <!-- Tag filter -->
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1 items-center">
      <span class="text-xs text-[var(--color-text-muted)] mr-1">标签:</span>
      <a
        href={`${currentPath}${activeRole ? `?role=${activeRole}` : ""}`}
        class={`tag-pill no-underline text-[10px] ${!activeTag ? "bg-white/10 text-[var(--color-text-primary)]" : "mechanic"}`}
      >{allLabel}</a>
      {tags.map(t => (
        <a
          href={`${currentPath}?tag=${t}${activeRole ? `&role=${activeRole}` : ""}`}
          class={`tag-pill no-underline text-[10px] ${activeTag === t ? "bg-white/15 text-[var(--color-text-primary)]" : "mechanic"}`}
        >{t}</a>
      ))}
    </div>
  )}
</div>

<script>
  const input = document.getElementById("filter-search") as HTMLInputElement;
  if (input) {
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const url = new URL(window.location.href);
        if (input.value) url.searchParams.set("search", input.value);
        else url.searchParams.delete("search");
        window.location.href = url.toString();
      }
    });
  }
</script>
