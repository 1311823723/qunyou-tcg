---
export interface Props {
  label: string;
  variant?: "role" | "mech" | "aggro";
  role?: string;
}
const { label, variant = "mech", role } = Astro.props;
import { roleVar } from "../lib/ui";
const roleClass = variant === "role" && role ? roleVar(role) : "";
const cls = variant === "role" ? `tag-pill tag-pill--role ${roleClass}` : variant === "aggro" ? "tag-pill tag-pill--aggro" : "tag-pill tag-pill--mech";
---
<span class={cls}>{label}</span>
