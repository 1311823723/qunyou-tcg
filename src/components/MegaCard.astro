---
import CardFrame from "./CardFrame.astro";
import type { MegaCard as MegaType } from "../lib/cards";

export interface Props { mega: MegaType; compact?: boolean; }
const { mega: m, compact } = Astro.props;
---
<CardFrame class={`tcg-mega ${compact ? "tcg-char--compact" : ""}`} kind="mega">
  <div class="tcg-mega__head">
    <span class="tcg-mega__badge">MEGA</span>
    <h3 class="tcg-mega__name">{m.name}</h3>
  </div>
  <div class="tcg-mega__skill">
    <div class="tcg-mega__skill-name">{m.skillName}</div>
    <p class="skill-text">{m.effectText}</p>
  </div>
  {m.notes && <p class="tcg-char__notes" style="margin: 0 1rem 1rem;">{m.notes}</p>}
</CardFrame>
